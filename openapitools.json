{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.23.0",
    "generators": {
      "paykit": {
        "generatorName": "typescript-axios",
        "inputSpec": "packages/template/openapi.json",
        "output": "packages/sdk",
        "additionalProperties": {
          "npmName": "paykit",
          "npmVersion": "1.0.0",
          "supportsES6": true,
          "withSeparateModelsAndApi": true,
          "apiPackage": "api",
          "modelPackage": "models",
          "useSingleRequestParameter": true,
          "withInterfaces": true
        }
      }
    }
  }
}
