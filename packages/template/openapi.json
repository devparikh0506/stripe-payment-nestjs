  "info": {
    "title": "Stripe Payment Service",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "x-api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "CreateCustomerDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "phone": {
            "type": "string",
            "example": "+15555555555"
          }
        },
        "required": [
          "email"
        ]
      },
      "UpdateCustomerDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "new@example.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "phone": {
            "type": "string",
            "example": "+15555555555"
          }
        }
      },
      "CreatePlanDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Pro Monthly"
          },
          "amount": {
            "type": "number",
            "example": 1900,
            "description": "Amount in smallest currency unit (cents)"
          },
          "currency": {
            "type": "string",
            "example": "usd"
          },
          "interval": {
            "type": "string",
            "example": "month",
            "enum": [
              "month",
              "year"
            ]
          }
        },
        "required": [
          "name",
          "amount",
          "currency",
          "interval"
        ]
      },
      "CreatePaymentDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "Local customer id (UUID)"
          },
          "amount": {
            "type": "number",
            "example": 4900,
            "description": "Amount in smallest currency unit (cents)"
          },
          "currency": {
            "type": "string",
            "example": "usd"
          },
          "idempotencyKey": {
            "type": "string",
            "description": "Pass the same key on retries to guarantee the charge is created at most once"
          }
        },
        "required": [
          "customerId",
          "amount",
          "currency"
        ]
      },
      "CreateSubscriptionDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "description": "Local customer id (UUID)"
          },
          "planId": {
            "type": "string",
            "description": "Local plan id (UUID)"
          },
          "trialPeriodDays": {
            "type": "number",
            "example": 14,
            "description": "Free trial length in days — Stripe schedules the first charge"
          },
          "idempotencyKey": {
            "type": "string",
            "description": "Pass the same key on retries to guarantee the subscription is created at most once"
          }
        },
        "required": [
          "customerId",
          "planId"
        ]
      }
    }
  }
}
