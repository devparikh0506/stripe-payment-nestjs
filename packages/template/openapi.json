    "/webhooks/stripe": {
      "post": {
        "operationId": "Webhooks_handleStripeWebhook",
        "parameters": [
          {
            "name": "stripe-signature",
            "required": true,
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Verify → dedup → enqueue → 200. No business logic here: Stripe\nretries anything that doesn't get a 2xx within ~10s, so the heavy\nwork happens in the background processor.",
